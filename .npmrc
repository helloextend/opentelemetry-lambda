registry="https://extend-159581800400.d.codeartifact.us-east-1.amazonaws.com/npm/extend-npm/"
# Require packages to be at least 7 days old (10080 minutes) before installation
# This helps protect against supply chain attacks from newly published malicious packages
minimum-release-age=10080
# Allow immediate installation of Extend packages
minimum-release-age-exclude[]='@extend/*'
minimum-release-age-exclude[]='@helloextend/*'
minimum-release-age-exclude[]='@extend-*/*'
minimum-release-age-exclude[]='extend-cdk-lib'
# Flat node_modules layout (npm-style) — simplifies Lambda layer packaging
# and avoids pnpm-isolated symlinks pointing outside package trees.
node-linker=hoisted
