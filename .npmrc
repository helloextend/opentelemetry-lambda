registry="https://extend-159581800400.d.codeartifact.us-east-1.amazonaws.com/npm/extend-npm/"
# Require packages to be at least 7 days old (10080 minutes) before installation
# This helps protect against supply chain attacks from newly published malicious packages
minimum-release-age=10080
# Allow immediate installation of Extend packages
minimum-release-age-exclude[]='@extend/*'
minimum-release-age-exclude[]='@helloextend/*'
minimum-release-age-exclude[]='@extend-*/*'
minimum-release-age-exclude[]='extend-cdk-lib'
# Flat node_modules layout (npm-style). Diverges from the Extend default
# (isolated, as used in arize-ai-integration-service and mastra-utils) because:
#   1. Lambda layer packaging requires a flat nodejs/node_modules/ tree; pnpm's
#      isolated symlink farm cannot be copied into a layer zip verbatim.
#   2. The cx-contrib fork (coralogix/opentelemetry-js-contrib) pins a specific
#      @types/node; isolated mode re-resolves it per-package and breaks its
#      pinned TypeScript build.
# Future workspaces under this repo (e.g. service/) that aren't layer-adjacent
# should add their own .npmrc with node-linker=isolated to match Extend convention.
node-linker=hoisted
